# ─── RCA Talent Frontend Environment ─────────────────────────────────────────
# Copy this file to .env.local and adjust values for your setup.

# Backend API (NestJS default: port 3000, versioned at /api/v1)
NEXT_PUBLIC_API_URL=http://localhost:3000/api/v1

# Use in-memory mock data instead of the real API (default: true)
# Set to false when the backend is running
NEXT_PUBLIC_USE_MOCK=true
