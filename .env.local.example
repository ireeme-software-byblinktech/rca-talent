# ─── RCA Talent Frontend Environment ─────────────────────────────────────────
# Copy this file to .env.local and adjust values for your setup.

# Backend API (includes /api/v1 prefix)
# Local:  http://localhost:5000/api/v1
# Render: https://rca-talent.onrender.com/api/v1
NEXT_PUBLIC_API_URL=https://rca-talent.onrender.com/api/v1

# Use in-memory mock data instead of the real API (default: true)
# Set to false when connecting to the real backend
NEXT_PUBLIC_USE_MOCK=false
